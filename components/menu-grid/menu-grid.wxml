<view class="menu-container">
  <block wx:if="{{foods.length === 0}}">
    <view class="menu-empty">
      <block wx:if="{{!isEditing}}">
        <view class="menu-add-btn" bindtap="onAddTap">＋</view>
      </block>
      <block wx:else>
        <input
          class="menu-input"
          placeholder="菜名，回车添加"
          focus
          bindconfirm="onInputConfirm"
          bindblur="onInputBlur"
        />
      </block>
    </view>
  </block>
  <block wx:else>
    <!-- 加号在最前面 -->
    <view class="menu-add-cell" wx:if="{{!isEditing}}">
      <view class="menu-add-btn" bindtap="onAddTap">＋</view>
    </view>
    <view class="menu-input-cell" wx:if="{{isEditing}}">
      <input
        class="menu-input"
        placeholder="菜名，回车添加"
        focus
        bindconfirm="onInputConfirm"
        bindblur="onInputBlur"
      />
    </view>

    <!-- 网格 items -->
    <view
      class="menu-item {{scanning && scanIndex === index ? 'scanning' : ''}} {{highlightIndex === index ? 'active' : ''}}"
      wx:for="{{foods}}"
      wx:key="index"
      data-index="{{index}}"
      data-item="{{item}}"
      bindtap="onItemTap"
      bindlongpress="onItemLongPress"
    >{{item}}</view>
  </block>
</view>
