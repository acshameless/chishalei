.menu-grid-container {
  width: 100%;
  height: 100%;
  padding: 40rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-wrap: wrap;
  align-content: flex-start;
  gap: 20rpx 24rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  pointer-events: auto;
  mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
}

.menu-grid-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-grid-item {
  padding: 12rpx 28rpx;
  font-size: 25rpx;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  color: var(--ink-mid);
  border: 1rpx solid var(--paper-dark);
  background: var(--card);
  border-radius: 12rpx;
  white-space: nowrap;
  transition: all 0.15s;
  letter-spacing: 0.04em;
}
.menu-grid-item:active {
  transform: scale(0.96);
  border-color: var(--lacquer);
  color: var(--lacquer);
}

.menu-grid-add {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid var(--paper-dark);
  background: var(--card);
  color: var(--ink-mid);
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  transition: all 0.15s;
}
.menu-grid-add:active {
  border-color: var(--lacquer);
  color: var(--lacquer);
  transform: scale(1.08);
}

.menu-grid-input {
  width: 280rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--paper-dark);
  background: var(--card);
  font-size: 26rpx;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  color: var(--ink);
  text-align: center;
}
.menu-grid-input:focus {
  border-color: var(--lacquer);
}
