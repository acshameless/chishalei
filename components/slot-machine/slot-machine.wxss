.slot-container {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.slot-column {
  flex: 1;
  height: 100%;
  overflow: hidden;
  position: relative;
}

.slot-strip {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  will-change: transform;
}

.slot-item {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--ink-mid);
  opacity: 0.45;
  letter-spacing: 0.05em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.slot-item.active {
  opacity: 1;
  color: var(--lacquer);
  font-size: 30rpx;
  font-weight: 600;
  transform: scale(1.07);
  text-shadow: 0 0 14rpx rgba(184, 84, 56, 0.18);
  transition: all 0.35s cubic-bezier(0.22, 0.8, 0.3, 1);
}
