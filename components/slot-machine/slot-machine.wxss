.slot-container {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  height: 100%;
  overflow: hidden;
  position: relative;
}

.slot-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 26rpx;
  color: var(--ink-light);
  letter-spacing: 0.1em;
  text-align: center;
  white-space: nowrap;
}

.slot-column {
  flex: 1;
  min-width: 0;
  height: 100%;
  overflow: hidden;
  position: relative;
}

.slot-strip {
  width: 100%;
}

.slot-item {
  height: 44px;
  line-height: 44px;
  text-align: center;
  font-size: 26rpx;
  color: var(--ink-mid);
  opacity: 0.45;
  letter-spacing: 0.05em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
}

.slot-item.active {
  opacity: 1;
  color: var(--lacquer-dim);
  font-size: 30rpx;
  font-weight: 600;
  transform: scale(1.07);
  text-shadow: 0 0 14rpx rgba(184, 84, 56, 0.18);
  transition: all 0.35s cubic-bezier(0.22, 0.8, 0.3, 1);
}

.slot-item.in-my-menu {
  opacity: 0.9;
  color: var(--lacquer-dim);
}
.slot-item.in-my-menu::before {
  content: '·';
  display: inline-block;
  margin-right: 8rpx;
  color: var(--lacquer);
  font-weight: 800;
}

/* 滚动时的动态模拟效果 */
.slot-column.spinning .slot-item {
  opacity: 0.15;
  transform: scaleY(0.9);
}
