<view class="pool-page">
  <view class="pool-header">
    <text class="pool-title">选菜池</text>
    <text class="pool-sub">勾选分类，展开可排除具体菜品</text>
  </view>

  <view class="category-list">
    <view
      class="category-item"
      wx:for="{{categories}}"
      wx:key="name"
      data-index="{{index}}"
    >
      <!-- 分类行 -->
      <view class="category-row" bindtap="onToggleCategory" data-index="{{index}}">
        <view class="checkbox {{item.selected ? 'checked' : ''}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
        <text class="category-name">{{item.name}}</text>
        <text class="category-count">{{item.items.length}} 道</text>
        <text class="expand-icon {{item.expanded ? 'expanded' : ''}}">▸</text>
      </view>

      <!-- 菜品展开 -->
      <view class="food-list {{item.expanded ? 'expanded' : ''}}">
        <view
          class="food-item {{item2.excluded ? 'excluded' : ''}}"
          wx:for="{{item.items}}"
          wx:for-item="item2"
          wx:for-index="idx2"
          wx:key="name"
          data-cat="{{index}}"
          data-food="{{idx2}}"
          bindtap="onToggleFood"
        >
          <text class="food-name">{{item2.name}}</text>
          <text class="food-status" wx:if="{{item2.excluded}}">已排除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="pool-footer">
    <text class="pool-stats">已选 {{selectedCount}} 个分类，共 {{totalFoods}} 道菜</text>
    <button class="back-btn" bindtap="onBack">完成</button>
  </view>
</view>
