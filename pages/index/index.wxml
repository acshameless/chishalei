<view class="page-container">

  <!-- upper-content -->
  <view class="upper-content">
    <view class="header">
      <view class="mark">
        <view class="mark-line"></view>
        <view class="mark-dot"></view>
        <view class="mark-line"></view>
      </view>
      <view class="title">吃啥嘞</view>
    </view>

    <view class="result-wrap">
      <view class="result-card {{isSpinning ? 'spinning' : ''}} {{landed ? 'landed' : ''}}">
        <view class="card-fx"></view>
        <view class="corner-tr"></view>
        <view class="corner-bl"></view>
        <view class="result-label">今儿个吃这个</view>
        <view class="result-food">{{resultText}}</view>
        <view class="result-tip {{tipVisible ? 'visible' : ''}}">
          <text class="tip-main">{{tipText}}</text>
          <text class="tip-sub">{{timeTip}}</text>
        </view>
        <view class="sign-number {{signNumber ? 'visible' : ''}}">第 {{signNumber}} 签</view>
      </view>
    </view>

    <view class="fortune-wrap {{fortuneVisible ? 'visible' : ''}}">
      <view class="fortune-text">{{fortuneText}}</view>
    </view>
  </view>

  <!-- btn-wrap -->
  <view class="btn-wrap">
    <button class="btn {{isSpinning ? 'is-spinning' : ''}}" bindtap="onSpin">
      <text class="btn-label">{{btnText}}</text>
      <view class="btn-rule"></view>
      <text class="btn-kanji">{{btnKanji}}</text>
    </button>
  </view>

  <!-- lower-content -->
  <view class="lower-content">
    <view class="share-row {{shareVisible ? 'visible' : ''}}">
      <button class="share-btn" bindtap="onSaveShareImage">分享</button>
      <button class="share-btn" bindtap="onToggleCook">{{cookBtnText}}</button>
    </view>

    <view class="control-row">
      <view class="pool-tabs">
        <text
          class="pool-tab {{currentPool === 'all' ? 'active' : ''}}"
          data-pool="all"
          bindtap="onSwitchPool"
        >全部选项</text>
        <text
          class="pool-tab {{currentPool === 'myMenu' ? 'active' : ''}}"
          data-pool="myMenu"
          bindtap="onSwitchPool"
        >我的菜单</text>
      </view>
      <button class="control-btn" bindtap="onGoPool">选</button>
      <button class="control-btn" bindtap="onShowHistory">历</button>
    </view>

    <!-- Slot machine / Menu grid -->
    <view class="machine-area">
      <slot-machine
        wx:if="{{currentPool === 'all'}}"
        foods="{{foods}}"
        spinning="{{isSpinning}}"
        targetIndex="{{targetIndex}}"
        bind:onComplete="onSpinComplete"
      />
      <menu-grid
        wx:if="{{currentPool === 'myMenu'}}"
        foods="{{foods}}"
        bind:onAdd="onMenuAdd"
        bind:onRemove="onMenuRemove"
      />
    </view>

    <view class="cook-wrap {{cookVisible ? 'visible' : ''}}">
      <scroll-view class="cook-scroll" scroll-y>
        <rich-text nodes="{{cookHtml}}"></rich-text>
      </scroll-view>
    </view>
  </view>

  <!-- Toast -->
  <view class="toast {{toastVisible ? 'visible' : ''}}">{{toastMsg}}</view>

  <!-- History overlay -->
  <view class="overlay {{historyVisible ? 'active' : ''}}" bindtap="onCloseHistory">
    <view class="panel" catchtap="onPanelTap">
      <view class="panel-header">
        <text class="panel-title">抽签历史</text>
        <text class="panel-close" bindtap="onCloseHistory">关闭</text>
      </view>
      <scroll-view class="panel-body" scroll-y>
        <block wx:if="{{historyList.length === 0}}">
          <view class="empty-text">暂无记录</view>
        </block>
        <block wx:else>
          <view class="history-item" wx:for="{{historyList}}" wx:key="index">
            <text class="history-name">{{item.name}}</text>
            <text class="history-time">{{item.timeStr}}</text>
          </view>
        </block>
      </scroll-view>
      <view class="panel-footer" wx:if="{{historyList.length > 0}}">
        <text class="clear-btn" bindtap="onClearHistory">清空</text>
      </view>
    </view>
  </view>

  <!-- Share overlay -->
  <view class="overlay {{shareOverlayVisible ? 'active' : ''}}" bindtap="onCloseShareOverlay">
    <view class="share-preview" catchtap="onPanelTap">
      <image class="share-img" src="{{shareImageUrl}}" mode="widthFix" show-menu-by-longpress />
      <view class="share-hint">长按保存图片</view>
      <button class="share-close" bindtap="onCloseShareOverlay">关闭</button>
    </view>
  </view>

  <!-- Hidden canvas for share card -->
  <canvas
    type="2d"
    id="shareCanvas"
    class="share-canvas"
    style="width: 540px; height: 960px;"
  />
</view>
