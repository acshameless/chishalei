page {
  --paper:       #F6F1E9;
  --paper-dark:  #E8DFD0;
  --card:        #FDFAF5;
  --ink:         #23201B;
  --ink-mid:     #6B6055;
  --ink-light:   #A89F94;
  --lacquer:     #B85438;
  --lacquer-lt:  #E8C4AE;
  --lacquer-dim: #8A3D27;
  background: var(--paper);
  color: var(--ink);
  min-height: 100vh;
  box-sizing: border-box;
}

::-webkit-scrollbar { display: none; }

/* ═══════════════════════════════════════
   Layout
   ═══════════════════════════════════════ */
.page-container {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 640px;
  margin: 0 auto;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 20px 40px;
  box-sizing: border-box;
  background-image: radial-gradient(circle, #CBC0AE 1px, transparent 1px);
  background-size: 28px 28px;
}

.upper-content {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  width: 100%;
  margin-top: 6vh;
}

.lower-content {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  width: 100%;
  flex: 1;
}

/* ═══════════════════════════════════════
   Header
   ═══════════════════════════════════════ */
.header { text-align: center; margin-top: 6vh; margin-bottom: 20px; }

.mark {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-bottom: 12px;
}
.mark-line { width: 32px; height: 1px; background: var(--lacquer); opacity: 0.65; }
.mark-dot  { width: 6px; height: 6px; border: 1.5px solid var(--lacquer); border-radius: 50%; opacity: 0.75; }

.title {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 90rpx;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: 0.14em;
  line-height: 1;
}

/* ═══════════════════════════════════════
   Result card
   ═══════════════════════════════════════ */
.result-wrap { width: 100%; margin-bottom: 16px; }

.result-card {
  background: var(--card);
  border: 1px solid var(--paper-dark);
  position: relative;
  padding: 24px 20px 20px;
  text-align: center;
  overflow: hidden;
}

/* Corner brackets */
.result-card::before, .result-card::after,
.corner-tr, .corner-bl {
  content: '';
  position: absolute;
  width: 16px; height: 16px;
  border-color: var(--lacquer);
  border-style: solid;
  opacity: 0.5;
}
.result-card::before { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
.result-card::after  { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }
.corner-tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
.corner-bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }

.result-label {
  font-size: 11px;
  color: var(--ink-light);
  letter-spacing: 0.3em;
  margin-bottom: 10px;
  font-weight: 300;
}

.result-food {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 110rpx;
  font-weight: 600;
  color: var(--lacquer-dim);
  letter-spacing: 0.1em;
  min-height: 1.4em;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-card.spinning .result-food {
  animation: text-flicker 0.14s steps(1) infinite;
}

@keyframes text-flicker {
  0%   { color: var(--lacquer-dim); }
  40%  { color: var(--ink-mid); }
  70%  { color: var(--lacquer); }
  100% { color: var(--lacquer-dim); }
}

/* Scan-line sweep */
.card-fx {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.result-card.spinning .card-fx::after {
  content: '';
  position: absolute;
  left: -10%; right: -10%;
  height: 45%;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(184,84,56,0.07) 40%,
    rgba(184,84,56,0.11) 50%,
    rgba(184,84,56,0.07) 60%,
    transparent 100%
  );
  animation: scan-sweep 1.1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes scan-sweep {
  0%   { top: -50%; }
  100% { top: 130%; }
}

/* Corner brackets pulse while spinning */
@keyframes corner-pulse {
  0%   { opacity: 0.3; width: 13px; height: 13px; }
  100% { opacity: 1;   width: 22px; height: 22px; }
}
.result-card.spinning::before { animation: corner-pulse 0.4s ease-in-out infinite alternate; }
.result-card.spinning::after  { animation: corner-pulse 0.4s 0.1s ease-in-out infinite alternate; }
.result-card.spinning .corner-tr { animation: corner-pulse 0.4s 0.05s ease-in-out infinite alternate; }
.result-card.spinning .corner-bl { animation: corner-pulse 0.4s 0.15s ease-in-out infinite alternate; }

/* Border tint while spinning */
.result-card.spinning { border-color: var(--lacquer-lt); }

/* Sign number */
.sign-number {
  position: absolute;
  bottom: 10px;
  right: 14px;
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 10px;
  color: var(--ink-light);
  letter-spacing: 0.12em;
  opacity: 0;
  transition: opacity 0.5s ease 0.6s;
}
.sign-number.visible { opacity: 0.45; }

/* Landing stamp animation */
.result-card.landed .result-food {
  animation: stamp 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes stamp {
  0%   { transform: scale(1.1); opacity: 0; filter: blur(3px); }
  55%  { filter: blur(0); }
  100% { transform: scale(1);   opacity: 1; }
}

/* Result tip */
.result-tip {
  margin-top: 8px;
  min-height: 2.2em;
  opacity: 0;
  transition: opacity 0.5s ease 0.4s;
  display: flex;
  flex-direction: column;
  gap: 2px;
  align-items: center;
  line-height: 1.5;
}
.result-tip.visible { opacity: 1; }
.tip-main {
  font-size: 12px;
  color: var(--ink-mid);
  letter-spacing: 0.06em;
}
.tip-sub {
  font-size: 11px;
  color: var(--ink-light);
  letter-spacing: 0.06em;
}

/* ═══════════════════════════════════════
   Fortune slip
   ═══════════════════════════════════════ */
.fortune-wrap {
  width: 100%;
  text-align: center;
  margin-top: 0;
  margin-bottom: 0;
  max-height: 0;
  min-height: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: max-height 0.4s ease, opacity 0.6s ease 0.3s, margin 0.4s ease;
}
.fortune-wrap.visible {
  max-height: 50px;
  min-height: 36px;
  margin-top: 0;
  margin-bottom: 8px;
  opacity: 1;
}
.fortune-text {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 12.5px;
  font-weight: 400;
  color: var(--ink-light);
  letter-spacing: 0.18em;
  line-height: 1.9;
}

/* ═══════════════════════════════════════
   Button
   ═══════════════════════════════════════ */
.btn-wrap { margin-top: 20px; margin-bottom: 20px; }

.btn {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: var(--lacquer);
  color: #FDF8F2;
  border: none;
  padding: 14px 44px;
  font-size: 15px;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  font-weight: 400;
  letter-spacing: 0.18em;
  box-shadow: 3px 3px 0 rgba(139,61,39,0.22);
  transition: background 0.2s, transform 0.12s, box-shadow 0.12s;
  line-height: 1;
  border-radius: 0;
}
.btn::after { border: none; }
.btn:active {
  background: var(--lacquer-dim);
  transform: translate(1px,1px);
  box-shadow: 1px 1px 0 rgba(139,61,39,0.18);
}

.btn.is-spinning {
  background: var(--ink);
  box-shadow: 3px 3px 0 rgba(0,0,0,0.18);
  letter-spacing: 0.22em;
  animation: btn-pulse 0.7s ease-in-out infinite alternate;
}

@keyframes btn-pulse {
  0%   { box-shadow: 3px 3px 0 rgba(0,0,0,0.18); }
  100% { box-shadow: 3px 3px 0 rgba(0,0,0,0.18), 0 0 0 4px rgba(35,32,27,0.08); }
}

.btn-rule { width: 1px; height: 14px; background: rgba(255,255,255,0.35); }

.btn-kanji {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 18px;
  font-weight: 400;
  opacity: 0.88;
  display: inline-block;
  transition: transform 0.55s ease;
}
.btn:not(.is-spinning):active .btn-kanji { transform: rotate(90deg); }
.btn.is-spinning .btn-kanji { animation: kanji-spin 0.6s linear infinite; }

@keyframes kanji-spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ═══════════════════════════════════════
   Share row
   ═══════════════════════════════════════ */
.share-row {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-bottom: 0;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.4s ease, opacity 0.5s ease 0.5s, margin-bottom 0.4s ease;
}
.share-row.visible {
  max-height: 44px;
  margin-bottom: 16px;
  opacity: 1;
}
.share-btn {
  background: none;
  border: 1px solid var(--paper-dark);
  padding: 6px 18px;
  font-size: 11px;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  font-weight: 300;
  color: var(--ink-light);
  letter-spacing: 0.15em;
  transition: all 0.2s ease;
  line-height: 1;
  border-radius: 0;
}
.share-btn::after { border: none; }
.share-btn:active {
  border-color: var(--lacquer);
  color: var(--lacquer);
}

/* ═══════════════════════════════════════
   Control row
   ═══════════════════════════════════════ */
.control-row {
  display: flex;
  gap: 10px;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 8px;
}

.pool-tabs {
  display: flex;
  gap: 18px;
  align-items: center;
}
.pool-tab {
  font-size: 11px;
  color: var(--ink-light);
  letter-spacing: 0.12em;
  padding: 6px 2px;
  border-bottom: 1px solid transparent;
  transition: color 0.2s, border-color 0.2s;
}
.pool-tab.active {
  color: var(--lacquer);
  border-bottom-color: var(--lacquer);
}

.control-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--paper-dark);
  background: var(--card);
  color: var(--ink-mid);
  font-size: 15px;
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  line-height: 1;
  flex-shrink: 0;
  padding: 0;
}
.control-btn::after { border: none; }
.control-btn:active {
  border-color: var(--lacquer);
  color: var(--lacquer);
  transform: scale(0.96);
}

/* ═══════════════════════════════════════
   Machine area
   ═══════════════════════════════════════ */
.machine-area {
  position: relative;
  width: 100%;
  height: 240px;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 14px;
}
.machine-area .slot-container,
.machine-area .menu-grid-container {
  pointer-events: auto;
}

/* ═══════════════════════════════════════
   Cook
   ═══════════════════════════════════════ */
.cook-wrap {
  width: 100%;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.5s ease, opacity 0.5s ease 0.2s, margin 0.4s ease;
}
.cook-wrap.visible {
  max-height: 600px;
  margin-top: 8px;
  margin-bottom: 8px;
  opacity: 1;
}
.cook-scroll {
  max-height: 600px;
  font-size: 12.5px;
  color: var(--ink-mid);
  line-height: 1.8;
  letter-spacing: 0.04em;
  background: var(--card);
  border: 1px solid var(--paper-dark);
  padding: 24px 28px;
  position: relative;
  box-sizing: border-box;
}
.cook-scroll::before, .cook-scroll::after {
  content: '';
  position: absolute;
  width: 14px; height: 14px;
  border-color: var(--lacquer);
  border-style: solid;
  opacity: 0.3;
}
.cook-scroll::before { top: -1px; left: -1px; border-width: 1.5px 0 0 1.5px; }
.cook-scroll::after  { bottom: -1px; right: -1px; border-width: 0 1.5px 1.5px 0; }

/* ═══════════════════════════════════════
   Toast
   ═══════════════════════════════════════ */
.toast {
  position: fixed;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%) translateY(12px);
  padding: 8px 18px;
  border-radius: 20px;
  background: rgba(35, 32, 27, 0.82);
  color: #F6F1E9;
  font-size: 13px;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  letter-spacing: 0.04em;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s ease, transform 0.35s ease;
  z-index: 200;
  white-space: nowrap;
}
.toast.visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ═══════════════════════════════════════
   Overlay (History & Share)
   ═══════════════════════════════════════ */
.overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(35,32,27,0.7);
  justify-content: center;
  align-items: center;
  padding: 24px;
}
.overlay.active { display: flex; }

.panel {
  background: var(--card);
  border: 1px solid var(--paper-dark);
  max-width: 420px;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}
.panel-header {
  padding: 14px 18px;
  border-bottom: 1px solid var(--paper-dark);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.panel-title {
  font-size: 14px;
  color: var(--ink);
  letter-spacing: 0.1em;
  font-weight: 500;
}
.panel-close {
  font-size: 12px;
  color: var(--ink-light);
  letter-spacing: 0.08em;
  padding: 4px 8px;
}
.panel-body {
  flex: 1;
  overflow-y: auto;
  padding: 12px 18px;
}
.panel-footer {
  padding: 12px 18px;
  border-top: 1px solid var(--paper-dark);
  text-align: center;
}
.empty-text {
  text-align: center;
  padding: 32px 20px;
  color: var(--ink-light);
  font-size: 12px;
  letter-spacing: 0.15em;
}
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--paper-dark);
}
.history-item:last-child { border-bottom: none; }
.history-name {
  font-size: 13px;
  color: var(--ink-mid);
}
.history-time {
  font-size: 11px;
  color: var(--ink-light);
}
.clear-btn {
  font-size: 12px;
  color: var(--lacquer);
  letter-spacing: 0.1em;
}

/* Share preview */
.share-preview {
  background: var(--card);
  border: 1px solid var(--paper-dark);
  padding: 20px;
  max-width: 380px;
  width: 100%;
  text-align: center;
  position: relative;
}
.share-img {
  width: 100%;
  height: auto;
  display: block;
  margin-bottom: 16px;
}
.share-hint {
  font-size: 11px;
  color: var(--ink-light);
  letter-spacing: 0.15em;
  font-weight: 300;
  margin-bottom: 12px;
}
.share-close {
  background: none;
  border: 1px solid var(--paper-dark);
  padding: 6px 24px;
  font-size: 12px;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  color: var(--ink-mid);
  letter-spacing: 0.12em;
  transition: all 0.15s;
  line-height: 1;
  border-radius: 0;
}
.share-close::after { border: none; }
.share-close:active {
  border-color: var(--lacquer);
  color: var(--lacquer);
}

/* Hidden canvas */
.share-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  opacity: 0;
  pointer-events: none;
}

/* Mobile */
@media (max-width: 480px) {
  .page-container { padding: 16px 12px 24px; }
  .header { margin-bottom: 16px; }
  .result-card { padding: 18px 16px 16px; }
  .btn { padding: 12px 36px; font-size: 14px; }
  .control-row { gap: 8px; padding: 0 8px; }
  .pool-tab { font-size: 10px; letter-spacing: 0.08em; padding: 5px 2px; }
  .control-btn { width: 36px; height: 36px; font-size: 13px; }
  .overlay { padding: 12px; }
  .panel, .share-preview { max-width: 100%; max-height: 85vh; }
}
