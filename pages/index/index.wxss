/* ═══════════════════════════════════════
   全局 / Page
   ═══════════════════════════════════════ */
page {
  --paper:       #F6F1E9;
  --paper-dark:  #E8DFD0;
  --card:        #FDFAF5;
  --ink:         #23201B;
  --ink-mid:     #6B6055;
  --ink-light:   #A89F94;
  --lacquer:     #B85438;
  --lacquer-lt:  #E8C4AE;
  --lacquer-dim: #8A3D27;
  background: var(--paper);
  color: var(--ink);
  min-height: 100vh;
  box-sizing: border-box;
}

::-webkit-scrollbar { display: none; }

/* ═══════════════════════════════════════
   Layout
   ═══════════════════════════════════════ */
.page-container {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 640px;
  margin: 0 auto;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 40rpx 80rpx;
  box-sizing: border-box;
  background-image: radial-gradient(circle, #CBC0AE 1px, transparent 1px);
  background-size: 28px 28px;
}
.page-container::before {
  content: '';
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse 80% 70% at 50% 38%, var(--paper) 0%, transparent 100%);
  opacity: 0.65;
  pointer-events: none;
  z-index: 0;
}

.container {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 640px;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.upper-content {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  width: 100%;
  flex-shrink: 0;
}

.lower-content {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  width: 100%;
  flex: 1;
}

/* ═══════════════════════════════════════
   Header
   ═══════════════════════════════════════ */
.header { text-align: center; margin-top: 6vh; margin-bottom: 20px; }

.mark {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.mark-line { width: 64rpx; height: 2rpx; background: var(--lacquer); opacity: 0.65; }
.mark-dot  { width: 12rpx; height: 12rpx; border: 3rpx solid var(--lacquer); border-radius: 50%; opacity: 0.75; }

.title {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 90rpx;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: 0.14em;
  line-height: 1;
}

/* ═══════════════════════════════════════
   Result card
   ═══════════════════════════════════════ */
.result-wrap { width: 100%; margin-bottom: 32rpx; }

.result-card {
  background: var(--card);
  border: 1px solid var(--paper-dark);
  position: relative;
  padding: 48rpx 40rpx 40rpx;
  text-align: center;
  overflow: hidden;
}

/* Corner brackets */
.result-card::before, .result-card::after,
.corner-tr, .corner-bl {
  content: '';
  position: absolute;
  width: 32rpx; height: 32rpx;
  border-color: var(--lacquer);
  border-style: solid;
  opacity: 0.5;
}
.result-card::before { top: -2rpx; left: -2rpx; border-width: 4rpx 0 0 4rpx; }
.result-card::after  { bottom: -2rpx; right: -2rpx; border-width: 0 4rpx 4rpx 0; }
.corner-tr { top: -2rpx; right: -2rpx; border-width: 4rpx 4rpx 0 0; }
.corner-bl { bottom: -2rpx; left: -2rpx; border-width: 0 0 4rpx 4rpx; }

.result-label {
  font-size: 22rpx;
  color: var(--ink-light);
  letter-spacing: 0.3em;
  margin-bottom: 20rpx;
  font-weight: 300;
}

.result-food {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 110rpx;
  font-weight: 600;
  color: var(--lacquer-dim);
  letter-spacing: 0.1em;
  min-height: 1.4em;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-card.spinning .result-food {
  animation: text-flicker 0.14s steps(1) infinite;
}

@keyframes text-flicker {
  0%   { color: var(--lacquer-dim); }
  40%  { color: var(--ink-mid); }
  70%  { color: var(--lacquer); }
  100% { color: var(--lacquer-dim); }
}

/* Scan-line sweep */
.card-fx {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}
.result-card.spinning .card-fx::after {
  content: '';
  position: absolute;
  left: -10%; right: -10%;
  height: 45%;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(184,84,56,0.07) 40%,
    rgba(184,84,56,0.11) 50%,
    rgba(184,84,56,0.07) 60%,
    transparent 100%
  );
  animation: scan-sweep 1.1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes scan-sweep {
  0%   { top: -50%; }
  100% { top: 130%; }
}

/* Corner brackets pulse while spinning */
@keyframes corner-pulse {
  0%   { opacity: 0.3; width: 26rpx; height: 26rpx; }
  100% { opacity: 1;   width: 44rpx; height: 44rpx; }
}
.result-card.spinning::before { animation: corner-pulse 0.4s ease-in-out infinite alternate; }
.result-card.spinning::after  { animation: corner-pulse 0.4s 0.1s ease-in-out infinite alternate; }
.result-card.spinning .corner-tr { animation: corner-pulse 0.4s 0.05s ease-in-out infinite alternate; }
.result-card.spinning .corner-bl { animation: corner-pulse 0.4s 0.15s ease-in-out infinite alternate; }

.result-card.spinning { border-color: var(--lacquer-lt); }

/* Sign number */
.sign-number {
  position: absolute;
  bottom: 20rpx;
  right: 28rpx;
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 20rpx;
  color: var(--ink-light);
  letter-spacing: 0.12em;
  opacity: 0;
  transition: opacity 0.5s ease 0.6s;
}
.sign-number.visible { opacity: 0.45; }

/* Landing stamp animation */
.result-food.landing {
  animation: stamp 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes stamp {
  0%   { transform: scale(1.1); opacity: 0; filter: blur(6rpx); }
  55%  { filter: blur(0); }
  100% { transform: scale(1);   opacity: 1; }
}

/* Result tip */
.result-tip {
  margin-top: 16rpx;
  min-height: 2.2em;
  opacity: 0;
  transition: opacity 0.5s ease 0.4s;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  align-items: center;
  line-height: 1.5;
}
.result-tip.visible { opacity: 1; }
.tip-main {
  font-size: 24rpx;
  color: var(--ink-mid);
  letter-spacing: 0.06em;
}
.tip-sub {
  font-size: 22rpx;
  color: var(--ink-light);
  letter-spacing: 0.06em;
}

/* ═══════════════════════════════════════
   Fortune slip
   ═══════════════════════════════════════ */
.fortune-wrap {
  width: 100%;
  text-align: center;
  max-height: 0;
  min-height: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: max-height 0.4s ease, opacity 0.6s ease 0.3s, margin 0.4s ease;
}
.fortune-wrap.visible {
  max-height: 100rpx;
  min-height: 72rpx;
  margin-top: 0;
  margin-bottom: 16rpx;
  opacity: 1;
}
.fortune-text {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 25rpx;
  font-weight: 400;
  color: var(--ink-light);
  letter-spacing: 0.18em;
  line-height: 1.9;
}
/* ═══════════════════════════════════════
   Button
   ═══════════════════════════════════════ */
.btn-wrap { margin-top: 40rpx; margin-bottom: 40rpx; }

.btn {
  display: inline-flex;
  align-items: center;
  gap: 24rpx;
  background: var(--lacquer);
  color: #FDF8F2;
  border: none;
  padding: 28rpx 80rpx;
  font-size: 30rpx;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  font-weight: 400;
  letter-spacing: 0.18em;
  box-shadow: 6rpx 6rpx 0 rgba(139,61,39,0.22);
  transition: background 0.2s, transform 0.12s, box-shadow 0.12s;
  line-height: 1;
  border-radius: 0;
  white-space: nowrap;
}
.btn::after { border: none; }
.btn:active {
  background: var(--lacquer-dim);
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 rgba(139,61,39,0.18);
}

.btn.is-spinning {
  background: var(--ink);
  box-shadow: 6rpx 6rpx 0 rgba(0,0,0,0.18);
  letter-spacing: 0.22em;
  animation: btn-pulse 0.7s ease-in-out infinite alternate;
}

@keyframes btn-pulse {
  0%   { box-shadow: 6rpx 6rpx 0 rgba(0,0,0,0.18); }
  100% { box-shadow: 6rpx 6rpx 0 rgba(0,0,0,0.18), 0 0 0 8rpx rgba(35,32,27,0.08); }
}

.btn-rule { width: 2rpx; height: 28rpx; background: rgba(255,255,255,0.35); }

.btn-kanji {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 36rpx;
  font-weight: 400;
  opacity: 0.88;
  display: inline-block;
  transition: transform 0.55s ease;
}
.btn:not(.is-spinning):active .btn-kanji { transform: rotate(90deg); }
.btn.is-spinning .btn-kanji { animation: kanji-spin 0.6s linear infinite; }

@keyframes kanji-spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ═══════════════════════════════════════
   Share row
   ═══════════════════════════════════════ */
.share-row {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 0;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.4s ease, opacity 0.5s ease 0.5s, margin-bottom 0.4s ease;
}
.share-row.visible {
  max-height: 88rpx;
  margin-bottom: 32rpx;
  opacity: 1;
}
.share-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: 1rpx solid var(--paper-dark);
  padding: 12rpx 36rpx;
  font-size: 22rpx;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  font-weight: 300;
  color: var(--ink-light);
  letter-spacing: 0.15em;
  transition: all 0.2s ease;
  line-height: 1;
}
.share-btn:active {
  border-color: var(--lacquer);
  color: var(--lacquer);
}

/* ═══════════════════════════════════════
   Control row
   ═══════════════════════════════════════ */
.control-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.pool-tabs {
  display: flex;
  gap: 36rpx;
  align-items: center;
}
.pool-tab {
  font-size: 22rpx;
  color: var(--ink-light);
  letter-spacing: 0.12em;
  padding: 12rpx 4rpx;
  border-bottom: 2rpx solid transparent;
  transition: color 0.2s, border-color 0.2s;
}
.pool-tab.active {
  color: var(--lacquer);
  border-bottom-color: var(--lacquer);
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  min-width: 80rpx;
  min-height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid var(--paper-dark);
  background: var(--card);
  color: var(--ink-mid);
  font-size: 30rpx;
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  line-height: 1;
  flex-shrink: 0;
  padding: 0;
}
.control-btn:active {
  border-color: var(--lacquer);
  color: var(--lacquer);
  transform: scale(0.96);
}
.control-btn.muted {
  opacity: 0.35;
  border-style: dashed;
}

/* ═══════════════════════════════════════
   Machine area
   ═══════════════════════════════════════ */
.machine-area {
  position: relative;
  width: 100%;
  height: 480rpx;
  z-index: 0;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
}
/* 横向贯穿的中心高亮条 */
.machine-area.has-winner::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 88rpx;
  background: rgba(184, 84, 56, 0.04);
  border-top: 1px solid rgba(184, 84, 56, 0.07);
  border-bottom: 1px solid rgba(184, 84, 56, 0.07);
  pointer-events: none;
  opacity: 1;
  transition: opacity 0.5s ease;
  z-index: 1;
}

/* ═══════════════════════════════════════
   Cook / 做法
   ═══════════════════════════════════════ */
.cook-wrap {
  width: 100%;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.5s ease, opacity 0.5s ease 0.2s, margin 0.4s ease;
}
.cook-wrap.visible {
  max-height: none;
  margin-top: 16rpx;
  margin-bottom: 16rpx;
  opacity: 1;
}
.cook-content {
  font-size: 25rpx;
  color: var(--ink-mid);
  line-height: 1.8;
  letter-spacing: 0.04em;
  max-width: 100%;
  width: 100%;
  background: var(--card);
  border: 2rpx solid var(--paper-dark);
  padding: 48rpx 56rpx;
  position: relative;
  box-sizing: border-box;
}
.cook-content::before, .cook-content::after {
  content: '';
  position: absolute;
  width: 28rpx; height: 28rpx;
  border-color: var(--lacquer);
  border-style: solid;
  opacity: 0.3;
}
.cook-content::before { top: -2rpx; left: -2rpx; border-width: 3rpx 0 0 3rpx; }
.cook-content::after  { bottom: -2rpx; right: -2rpx; border-width: 0 3rpx 3rpx 0; }

.cook-section { margin-bottom: 40rpx; }
.cook-section:last-child { margin-bottom: 0; }
.cook-section-title {
  font-size: 21rpx;
  color: var(--lacquer);
  letter-spacing: 0.22em;
  margin-bottom: 20rpx;
  font-weight: 600;
  text-transform: uppercase;
}
.cook-materials-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 40rpx;
}
.cook-material-item {
  font-size: 24rpx;
  display: flex;
  gap: 12rpx;
  align-items: baseline;
}
.cook-material-name { color: var(--ink); font-weight: 500; }
.cook-material-amount { color: var(--ink-light); font-size: 22rpx; }

.cook-step {
  display: flex;
  gap: 28rpx;
  margin-bottom: 32rpx;
  padding-bottom: 28rpx;
  border-bottom: 2rpx dashed var(--paper-dark);
}
.cook-step:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}
.cook-step-num {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 36rpx;
  color: var(--lacquer);
  line-height: 1.2;
  flex-shrink: 0;
  min-width: 52rpx;
  text-align: center;
  opacity: 0.8;
}
.cook-step-body { flex: 1; }
.cook-step-title {
  font-size: 26rpx;
  color: var(--ink);
  font-weight: 600;
  margin-bottom: 8rpx;
  letter-spacing: 0.04em;
}
.cook-step-desc {
  font-size: 24rpx;
  color: var(--ink-mid);
  line-height: 1.7;
}
.cook-step-why {
  font-size: 22rpx;
  color: var(--ink-light);
  margin-top: 8rpx;
  font-style: italic;
  letter-spacing: 0.03em;
}
.cook-step-why::before { content: '→ '; color: var(--lacquer-lt); }
.cook-step-heat {
  font-size: 22rpx;
  color: var(--lacquer-dim);
  margin-top: 12rpx;
  letter-spacing: 0.05em;
  display: inline-block;
  padding: 4rpx 16rpx;
  background: var(--paper);
  border-radius: 4rpx;
}
.cook-tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.cook-tips-item {
  font-size: 23rpx;
  color: var(--ink-mid);
  line-height: 1.7;
  padding-left: 32rpx;
  position: relative;
}
.cook-tips-item::before {
  content: '·';
  position: absolute;
  left: 4rpx;
  color: var(--lacquer);
  font-weight: 600;
}

/* Cook loading */
.cook-loading {
  text-align: center;
  padding: 64rpx 40rpx;
  color: var(--ink-light);
  font-size: 24rpx;
  letter-spacing: 0.15em;
}
.cook-loading-dots {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 32rpx;
  align-items: center;
}
.cook-loading-dots view {
  width: 10rpx;
  height: 10rpx;
  background: var(--lacquer);
  border-radius: 50%;
  opacity: 0.25;
  animation: cook-dot-pulse 1.6s ease-in-out infinite;
}
.cook-loading-dots view:nth-child(2) { animation-delay: 0.25s; }
.cook-loading-dots view:nth-child(3) { animation-delay: 0.5s; }
@keyframes cook-dot-pulse {
  0%, 100% { opacity: 0.25; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.3); }
}

/* ═══════════════════════════════════════
   Toast
   ═══════════════════════════════════════ */
.toast {
  position: fixed;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%) translateY(24rpx);
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  background: rgba(35, 32, 27, 0.82);
  color: #F6F1E9;
  font-size: 26rpx;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  letter-spacing: 0.04em;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s ease, transform 0.35s ease;
  z-index: 200;
  white-space: nowrap;
}
.toast.visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ═══════════════════════════════════════
   Share overlay
   ═══════════════════════════════════════ */
.share-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: rgba(35,32,27,0.7);
  justify-content: center;
  align-items: center;
  padding: 48rpx;
}
.share-overlay.active { display: flex; }

.share-preview {
  background: var(--card);
  border: 2rpx solid var(--paper-dark);
  padding: 40rpx;
  max-width: 380px;
  width: 100%;
  text-align: center;
  position: relative;
}
.share-img {
  width: 100%;
  height: auto;
  display: block;
  margin-bottom: 32rpx;
}
.share-hint {
  font-size: 22rpx;
  color: var(--ink-light);
  letter-spacing: 0.15em;
  font-weight: 300;
  margin-bottom: 24rpx;
}
.share-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(246, 241, 233, 0.85);
  border: 2rpx solid var(--paper-dark);
  color: var(--ink-mid);
  font-size: 32rpx;
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  line-height: 1;
  padding: 0;
  padding-bottom: 4rpx;
  transition: all 0.15s;
}
.share-nav::after { border: none; }
.share-nav:active {
  background: var(--card);
  border-color: var(--lacquer);
  color: var(--lacquer);
}
.share-nav.prev { left: 12rpx; }
.share-nav.next { right: 12rpx; }

.share-slider {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  margin-bottom: 24rpx;
}
.share-slider::-webkit-scrollbar { display: none; }
.share-slider image {
  width: 100%;
  height: auto;
  flex-shrink: 0;
  scroll-snap-align: center;
  display: block;
}
.share-dots {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 24rpx;
}
.share-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--paper-dark);
  opacity: 0.4;
  transition: all 0.2s;
}
.share-dot.active {
  background: var(--lacquer);
  opacity: 1;
}

/* ═══════════════════════════════════════
   History overlay
   ═══════════════════════════════════════ */
.history-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: rgba(35,32,27,0.7);
  justify-content: center;
  align-items: center;
  padding: 48rpx;
}
.history-overlay.active { display: flex; }

.history-panel {
  background: var(--card);
  border: 2rpx solid var(--paper-dark);
  max-width: 420px;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}
.history-header {
  padding: 28rpx 36rpx;
  border-bottom: 2rpx solid var(--paper-dark);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.history-title {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 30rpx;
  letter-spacing: 0.12em;
  color: var(--ink);
}
.history-clear {
  font-size: 22rpx;
  color: var(--ink-light);
  background: none;
  border: none;
  letter-spacing: 0.08em;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  padding: 8rpx 16rpx;
}
.history-clear::after { border: none; }
.history-list {
  overflow-y: auto;
  padding: 16rpx 0;
  flex: 1;
}
.history-empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--ink-light);
  font-size: 24rpx;
  letter-spacing: 0.08em;
}
.history-item {
  padding: 20rpx 36rpx;
  border-bottom: 2rpx dashed var(--paper-dark);
}
.history-item:last-child { border-bottom: none; }
.history-item-date {
  font-size: 20rpx;
  color: var(--ink-light);
  margin-bottom: 8rpx;
  letter-spacing: 0.06em;
}
.history-item-main {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 24rpx;
}
.history-item-name {
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  font-size: 28rpx;
  color: var(--lacquer-dim);
  letter-spacing: 0.06em;
}
.history-item-sign {
  font-size: 20rpx;
  color: var(--ink-light);
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  letter-spacing: 0.08em;
  white-space: nowrap;
}
.history-item-fortune {
  font-size: 22rpx;
  color: var(--ink-mid);
  margin-top: 6rpx;
  letter-spacing: 0.04em;
}
.history-item-tip {
  font-size: 21rpx;
  color: var(--ink-light);
  margin-top: 4rpx;
  letter-spacing: 0.03em;
}
/* ═══════════════════════════════════════
   Category picker overlay
   ═══════════════════════════════════════ */
.category-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: rgba(35,32,27,0.7);
  justify-content: center;
  align-items: center;
  padding: 48rpx;
}
.category-overlay.active { display: flex; }

.category-panel {
  background: var(--card);
  border: 2rpx solid var(--paper-dark);
  max-width: 420px;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}
.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 2rpx solid var(--paper-dark);
}
.category-title {
  font-size: 32rpx;
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  color: var(--ink);
  letter-spacing: 0.1em;
}
.category-list {
  overflow-y: auto;
  flex: 1;
  padding: 8rpx 0;
}
.category-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 0;
  transition: background 0.15s;
  border-bottom: 2rpx solid transparent;
}
.category-row-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 40rpx;
}
.category-checkbox {
  margin-right: 16rpx;
  font-size: 28rpx;
  color: var(--lacquer);
  min-width: 36rpx;
  text-align: center;
}
.category-row-name {
  font-size: 28rpx;
  font-family: 'Shippori Mincho B1', 'Noto Serif SC', 'Songti SC', serif;
  color: var(--ink);
  letter-spacing: 0.08em;
  flex: 1;
}
.category-row-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.category-row-count {
  font-size: 22rpx;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  color: var(--ink-light);
  white-space: nowrap;
}
.category-expand {
  background: none;
  border: none;
  font-size: 22rpx;
  color: var(--ink-light);
  padding: 4rpx 16rpx;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  margin-left: 8rpx;
  transition: color 0.15s;
  white-space: nowrap;
  line-height: 1;
}
.category-expand::after { border: none; }
.category-expand:active { color: var(--lacquer); }
.category-items {
  padding: 0 40rpx 24rpx 96rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 16rpx;
}
.category-item {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-family: 'Zen Kaku Gothic New', sans-serif;
  color: var(--ink-mid);
  border: 2rpx solid var(--paper-dark);
  background: var(--card);
  white-space: nowrap;
  transition: all 0.15s;
}
.category-item.excluded {
  opacity: 0.35;
  text-decoration: line-through;
  border-color: transparent;
  background: transparent;
}
.category-item:active {
  border-color: var(--lacquer);
  color: var(--lacquer);
}

/* ═══════════════════════════════════════
   Hidden canvas
   ═══════════════════════════════════════ */
.share-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  opacity: 0;
  pointer-events: none;
}

/* Mobile */
@media (max-width: 480px) {
  .page-container { padding: 32rpx 24rpx 48rpx; }
  .header { margin-bottom: 32rpx; }
  .result-card { padding: 36rpx 32rpx 32rpx; }
  .btn { padding: 24rpx 72rpx; font-size: 28rpx; }
  .control-row { gap: 16rpx; padding: 0 16rpx; }
  .pool-tab { font-size: 20rpx; letter-spacing: 0.08em; padding: 10rpx 4rpx; }
  .control-btn { width: 72rpx; height: 72rpx; min-width: 72rpx; min-height: 72rpx; font-size: 26rpx; }
  .share-overlay, .history-overlay, .category-overlay { padding: 24rpx; }
  .share-preview { max-width: 100%; }
  .history-panel, .category-panel { max-width: 100%; max-height: 70vh; }
  .history-header, .category-header { padding: 24rpx 28rpx; }
  .machine-area { height: 400rpx; }
}
